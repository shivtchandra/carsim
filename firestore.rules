rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function proFieldsUnchanged() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return !affected.hasAny(['isPro','proPaymentId','proPlan','proExpiresAt','proUpdatedAt','proSource','proRazorpayOrderId']);
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId && (!('isPro' in request.resource.data) || request.resource.data.isPro == false);
      allow update: if request.auth != null && request.auth.uid == userId && proFieldsUnchanged();
      allow delete: if false;

      match /payments/{paymentId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    match /coupons/{code} {
      allow read, write: if false;
      match /redemptions/{userId} {
        allow read, write: if false;
      }
    }

    match /communityWallPosts/{postId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.approvedAt == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 20
        && request.resource.data.text.size() <= 1500
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() >= 1
        && request.resource.data.authorName.size() <= 40
        && request.resource.data.modelId is string
        && request.resource.data.modelId.size() >= 2
        && request.resource.data.modelId.size() <= 80;
      allow update: if (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['helpfulCount'])
          && request.resource.data.helpfulCount is int
          && request.resource.data.helpfulCount == resource.data.get('helpfulCount', 0) + 1
        ) || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','approvedAt','rejectedAt'])
          && request.resource.data.status in ['approved','rejected']
        );
      allow delete: if false;
    }

  }
}
